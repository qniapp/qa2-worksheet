{
  "name": "qa2-worksheet",
  "version": "1.0.0",
  "description": "QA2 を題材にした小学生向け夏休み自由研究ワークシート（量子ゲートの観察ノート）を手続き的に生成し、印刷用 PDF を書き出す。",
  "type": "module",
  "private": true,
  "scripts": {
    "html": "node build.mjs",
    "build": "bash build.sh",
    "render:review-pages": "node scripts/render-pdf-pages.mjs dist/qa2-worksheet.pdf ${REVIEW_DIR:-docs/review/issue-1}",
    "test:visual": "node scripts/check-visual-regression.mjs",
    "update:visual-baseline": "node scripts/check-visual-regression.mjs --update",
    "lint": "eslint .",
    "pretest": "npm run html",
    "test": "node --test",
    "audit": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "budoux": "^0.8.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0"
  },
  "overrides": {
    "gaxios": "^7.1.5"
  }
}
